---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/react/ContactForm';
import { getLocaleFromUrl, t } from '../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const labels = {
  name: t(locale, 'contact.name'),
  org: t(locale, 'contact.org'),
  email: t(locale, 'contact.email'),
  domain: t(locale, 'contact.domain'),
  message: t(locale, 'contact.message'),
  send: t(locale, 'contact.send'),
  success: t(locale, 'contact.success'),
};
---

<Layout title={t(locale, 'contact.title')} description="Solicita demo sau contacteaza-ne pentru o prezentare a solutiilor noastre AI.">
  <section class="pt-28 pb-20 lg:pt-36">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-navy text-center mb-4">
        {t(locale, 'contact.title')}
      </h1>
      <p class="text-text-light text-center mb-12">
        {t(locale, 'contact.sub')}
      </p>

      <div class="bg-white p-8 rounded-2xl border border-gray-100 shadow-sm">
        <ContactForm labels={labels} client:load />
      </div>
    </div>
  </section>
</Layout>
