---
import { getLocaleFromUrl, t, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const solutions = [
  {
    name: 'CBAM',
    descKey: 'solutions.cbam.desc',
    bullets: ['solutions.cbam.b1', 'solutions.cbam.b2', 'solutions.cbam.b3'],
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/cbam' : '/solutii/cbam'),
    ctaKey: 'solutions.viewDemo',
    badge: 'solutions.demoAvailable',
    badgeColor: 'bg-emerald-50 text-emerald-700',
  },
  {
    name: 'EUDR',
    descKey: 'solutions.eudr.desc',
    bullets: ['solutions.eudr.b1', 'solutions.eudr.b2', 'solutions.eudr.b3'],
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/eudr' : '/solutii/eudr'),
    ctaKey: 'solutions.viewConcept',
    badge: 'solutions.inPreparation',
    badgeColor: 'bg-amber-50 text-amber-700',
  },
  {
    name: 'ePaap',
    descKey: 'solutions.epaap.desc',
    bullets: ['solutions.epaap.b1', 'solutions.epaap.b2', 'solutions.epaap.b3'],
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/epaap' : '/solutii/epaap'),
    demoUrl: 'https://demo-epaap.bid-management.ro/autentificare',
    ctaKey: 'solutions.viewDemo',
    badge: 'solutions.demoAvailable',
    badgeColor: 'bg-emerald-50 text-emerald-700',
  },
  {
    name: 'FindEquip',
    descKey: 'solutions.findequip.desc',
    bullets: ['solutions.findequip.b1', 'solutions.findequip.b2', 'solutions.findequip.b3'],
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/findequip' : '/solutii/findequip'),
    demoUrl: 'https://findequip.bid-management.ro/dashboard',
    ctaKey: 'solutions.viewDemo',
    badge: 'solutions.demoAvailable',
    badgeColor: 'bg-emerald-50 text-emerald-700',
  },
  {
    name: 'Retail Reconciliation',
    descKey: 'solutions.retail.desc',
    bullets: ['solutions.retail.b1', 'solutions.retail.b2', 'solutions.retail.b3'],
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/retail' : '/solutii/retail'),
    ctaKey: 'solutions.viewSolution',
    badge: 'solutions.inPreparation',
    badgeColor: 'bg-amber-50 text-amber-700',
  },
];
---

<section class="py-20" id="solutii">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-3xl lg:text-4xl font-bold text-navy text-center mb-14">
      {t(locale, 'solutions.title')}
    </h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {solutions.map((sol, i) => (
        <div class="flex flex-col p-6 bg-white rounded-2xl border border-gray-100 hover:shadow-lg transition-all duration-300" data-animate data-animate-delay={String((i % 4) + 1)}>
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-heading text-lg font-bold text-navy">{sol.name}</h3>
            <span class={`text-xs font-medium px-2.5 py-1 rounded-full ${sol.badgeColor}`}>
              {t(locale, sol.badge)}
            </span>
          </div>
          <p class="text-sm text-text-light leading-relaxed mb-4 flex-1">{t(locale, sol.descKey)}</p>
          <ul class="space-y-2 mb-6">
            {sol.bullets.map(b => (
              <li class="flex items-start gap-2 text-sm text-text">
                <svg class="w-4 h-4 text-primary flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                {t(locale, b)}
              </li>
            ))}
          </ul>
          <div class="flex items-center gap-4">
            {sol.demoUrl && (
              <a href={sol.demoUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-semibold text-white bg-primary px-3.5 py-1.5 rounded-lg hover:bg-primary-light transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                Demo
              </a>
            )}
            <a href={sol.href} class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary-light transition-colors">
              {t(locale, sol.demoUrl ? 'solutions.viewSolution' : sol.ctaKey)}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
