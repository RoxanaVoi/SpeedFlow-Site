---
import { getLocaleFromUrl, t, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const cards = [
  {
    titleKey: 'whatWeDo.importers.title',
    descKey: 'whatWeDo.importers.desc',
    bullets: ['whatWeDo.importers.b1', 'whatWeDo.importers.b2', 'whatWeDo.importers.b3'],
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/cbam' : '/solutii/cbam'),
    icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3',
  },
  {
    titleKey: 'whatWeDo.public.title',
    descKey: 'whatWeDo.public.desc',
    bullets: ['whatWeDo.public.b1', 'whatWeDo.public.b2', 'whatWeDo.public.b3'],
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/epaap' : '/solutii/epaap'),
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  },
  {
    titleKey: 'whatWeDo.operators.title',
    descKey: 'whatWeDo.operators.desc',
    bullets: ['whatWeDo.operators.b1', 'whatWeDo.operators.b2', 'whatWeDo.operators.b3'],
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/findequip' : '/solutii/findequip'),
    icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
  },
  {
    titleKey: 'whatWeDo.retail.title',
    descKey: 'whatWeDo.retail.desc',
    bullets: ['whatWeDo.retail.b1', 'whatWeDo.retail.b2', 'whatWeDo.retail.b3'],
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/retail' : '/solutii/retail'),
    icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  },
];
---

<section class="py-20 bg-surface" id="ce-facem">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-3xl lg:text-4xl font-bold text-navy text-center mb-14">
      {t(locale, 'whatWeDo.title')}
    </h2>

    <div class="grid md:grid-cols-2 gap-6">
      {cards.map((card, i) => (
        <a href={card.href} class="group block p-8 bg-white rounded-2xl border border-gray-100 hover:border-primary/30 hover:shadow-lg transition-all duration-300" data-animate data-animate-delay={String(i + 1)}>
          <div class="flex items-start gap-4 mb-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={card.icon}/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-xl font-semibold text-navy group-hover:text-primary transition-colors">
                {t(locale, card.titleKey)}
              </h3>
            </div>
          </div>
          <p class="text-text-light mb-5 leading-relaxed">{t(locale, card.descKey)}</p>
          <ul class="space-y-2">
            {card.bullets.map(b => (
              <li class="flex items-center gap-2 text-sm text-text">
                <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                {t(locale, b)}
              </li>
            ))}
          </ul>
        </a>
      ))}
    </div>
  </div>
</section>
