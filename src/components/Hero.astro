---
import { getLocaleFromUrl, t, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
---

<section class="relative pt-28 pb-16 lg:pt-36 lg:pb-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div>
        <span class="inline-block px-4 py-1.5 bg-primary/10 text-primary text-sm font-medium rounded-full mb-6">
          {t(locale, 'hero.eyebrow')}
        </span>
        <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-navy leading-tight mb-6">
          {t(locale, 'hero.h1')}
        </h1>
        <p class="text-lg text-text-light leading-relaxed mb-8 max-w-xl">
          {t(locale, 'hero.sub')}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
          <a href={getLocalizedPath(locale, '/contact')} class="px-7 py-3.5 bg-primary text-white font-semibold rounded-lg hover:bg-primary-light transition-colors text-center">
            {t(locale, 'hero.cta1')}
          </a>
          <a href="#solutii" class="px-7 py-3.5 border-2 border-gray-200 text-navy font-semibold rounded-lg hover:border-primary hover:text-primary transition-colors text-center">
            {t(locale, 'hero.cta2')}
          </a>
        </div>
        <p class="text-sm text-text-light">
          {t(locale, 'hero.reassurance')}
        </p>
      </div>

      <!-- Right: Process Visual -->
      <div class="hidden lg:block">
        <div class="relative bg-surface rounded-2xl p-8 border border-gray-100">
          <div class="space-y-4">
            {[
              { key: 'process.step1', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', color: 'bg-blue-50 text-blue-600' },
              { key: 'process.step2', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', color: 'bg-primary/10 text-primary' },
              { key: 'process.step3', icon: 'M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4', color: 'bg-amber-50 text-amber-600' },
              { key: 'process.step4', icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', color: 'bg-emerald-50 text-emerald-600' },
            ].map((step, i) => (
              <div class="flex items-center gap-4 p-4 bg-white rounded-xl border border-gray-50 shadow-sm" data-animate data-animate-delay={String(i + 1)}>
                <div class={`w-12 h-12 rounded-xl ${step.color} flex items-center justify-center flex-shrink-0`}>
                  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={step.icon}/>
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="font-medium text-navy text-sm">{t(locale, step.key)}</p>
                </div>
                {i < 3 && (
                  <svg class="w-5 h-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
                  </svg>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
