---
import { getLocaleFromUrl, t } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const steps = [
  { titleKey: 'howItWorks.step1.title', descKey: 'howItWorks.step1.desc', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z' },
  { titleKey: 'howItWorks.step2.title', descKey: 'howItWorks.step2.desc', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
  { titleKey: 'howItWorks.step3.title', descKey: 'howItWorks.step3.desc', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
  { titleKey: 'howItWorks.step4.title', descKey: 'howItWorks.step4.desc', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15' },
];
---

<section class="py-20 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-3xl lg:text-4xl font-bold text-navy text-center mb-14">
      {t(locale, 'howItWorks.title')}
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, i) => (
        <div class="text-center" data-animate data-animate-delay={String(i + 1)}>
          <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={step.icon}/>
            </svg>
          </div>
          <div class="w-8 h-8 bg-primary text-white rounded-full flex items-center justify-center text-sm font-bold mx-auto mb-4">
            {i + 1}
          </div>
          <h3 class="font-heading text-lg font-semibold text-navy mb-2">{t(locale, step.titleKey)}</h3>
          <p class="text-sm text-text-light leading-relaxed">{t(locale, step.descKey)}</p>
        </div>
      ))}
    </div>
  </div>
</section>
