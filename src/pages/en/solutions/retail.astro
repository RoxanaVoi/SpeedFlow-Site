---
import SolutionLayout from '../../../layouts/SolutionLayout.astro';
---

<SolutionLayout
  title="Retail Reconciliation - Document reconciliation"
  description="Automation for internal document reconciliation and exception handling in repetitive processes."
  heroTitle="Automatic document reconciliation"
  heroProblem="Internal reconciliation processes involve repetitive checks between documents, identifying discrepancies and handling exceptions manually."
  heroResult="We automate document matching, identify exceptions and ensure decision traceability."
  forWhom="Companies with high volumes of internal documents requiring periodic reconciliation and structured exception handling."
  forWhomItems={[
    "Financial-accounting departments",
    "Retail operations and back-office",
    "Internal audit teams",
    "Companies with high volumes of invoices and documents",
  ]}
  processes={[
    "Import and structure documents for reconciliation",
    "Automatic matching based on configured rules",
    "Discrepancy and exception identification",
    "Exception escalation to responsible parties",
    "Exception handling and resolution with decision journal",
    "Reporting and audit trail",
  ]}
  howItWorks={[
    { title: "Document import", desc: "Documents are imported from various sources and automatically structured." },
    { title: "Automatic matching", desc: "Reconciliation rules are automatically applied to document sets." },
    { title: "Exception handling", desc: "Discrepancies are identified and escalated to responsible persons." },
    { title: "Audit trail", desc: "Every decision and action is recorded for complete traceability." },
  ]}
  outputs={[
    "Reconciliation report with matching status",
    "Exception list with prioritization",
    "Decision journal and audit trail",
    "Real-time monitoring dashboard",
    "Audit report exports",
  ]}
  faq={[
    { q: "What types of documents can be reconciled?", a: "Invoices, delivery notes, orders, receipts, bank statements and other structured documents." },
    { q: "Can specific rules be configured?", a: "Yes, matching rules are configurable per document type and process." },
    { q: "Is a demo available?", a: "The solution is in preparation. Contact us for a presentation of the proposed scenario." },
  ]}
  demoAvailable={false}
/>
