---
import SolutionLayout from '../../../layouts/SolutionLayout.astro';
---

<SolutionLayout
  title="EUDR - Compliance and traceability"
  description="Support for EUDR processes, document traceability and organizing compliance data."
  heroTitle="Support for EUDR compliance"
  heroProblem="The EUDR regulation requires supply chain traceability and complex documentation for targeted products."
  heroResult="We organize data, documents and traceability needed for EUDR compliance."
  forWhom="Companies importing or trading products subject to EUDR that need documented traceability."
  forWhomItems={[
    "Importers of wood, rubber, coffee, cocoa, soy, palm oil, cattle",
    "Companies with complex supply chains",
    "Compliance and sustainability departments",
    "Operators and traders subject to EUDR",
  ]}
  processes={[
    "Supply chain and supplier mapping",
    "Traceability document collection and organization",
    "Compliance validation per lot/delivery",
    "Due diligence statement generation",
    "Data monitoring and updates",
  ]}
  howItWorks={[
    { title: "Supplier mapping", desc: "We identify and structure information about suppliers and product origins." },
    { title: "Document collection", desc: "We centralize traceability documents, certificates and declarations." },
    { title: "Compliance validation", desc: "We verify completeness and correctness of documentation for each lot." },
    { title: "Report generation", desc: "We prepare declarations and reports required by authorities." },
  ]}
  outputs={[
    "Structured traceability registry",
    "Due diligence declarations",
    "Per-supplier compliance status dashboard",
    "Alerts for missing or expired documents",
  ]}
  faq={[
    { q: "What products are targeted?", a: "Wood, rubber, coffee, cocoa, soy, palm oil and cattle, including derived products." },
    { q: "When does EUDR take effect?", a: "The regulation applies to large operators from December 30, 2025, with progressive implementation." },
    { q: "Is a demo available?", a: "The solution is in concept phase. Contact us for a presentation of the proposed approach." },
  ]}
  demoAvailable={false}
/>
