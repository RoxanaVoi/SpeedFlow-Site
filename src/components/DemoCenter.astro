---
import { getLocaleFromUrl, t, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const demos = [
  {
    name: 'CBAM',
    useCase: locale === 'ro' ? 'Validare date emisii si generare raport trimestrial' : 'Emissions data validation and quarterly report generation',
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/cbam' : '/solutii/cbam'),
    ctaKey: 'demos.explore',
    duration: 'demos.duration',
    available: true,
    external: false,
  },
  {
    name: 'ePaap',
    useCase: locale === 'ro' ? 'Completare referat cu validari si flux de aprobare' : 'Document completion with validations and approval workflow',
    href: 'https://demo-epaap.bid-management.ro/autentificare',
    ctaKey: 'demos.explore',
    duration: 'demos.guidedTour',
    available: true,
    external: true,
  },
  {
    name: 'FindEquip',
    useCase: locale === 'ro' ? 'Cautare echipamente dupa cerinte din caietul de sarcini' : 'Equipment search by specification requirements',
    href: 'https://findequip.bid-management.ro/dashboard',
    ctaKey: 'demos.explore',
    duration: 'demos.duration',
    available: true,
    external: true,
  },
  {
    name: 'EUDR',
    useCase: locale === 'ro' ? 'Trasabilitate si conformitate pe lantul de aprovizionare' : 'Supply chain traceability and compliance',
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/eudr' : '/solutii/eudr'),
    ctaKey: 'demos.seeConcept',
    duration: 'demos.comingSoon',
    available: false,
    external: false,
  },
  {
    name: 'Retail Reconciliation',
    useCase: locale === 'ro' ? 'Reconciliere facturi si tratare exceptii automat' : 'Invoice reconciliation and automatic exception handling',
    href: getLocalizedPath(locale, locale === 'en' ? '/solutions/retail' : '/solutii/retail'),
    ctaKey: 'demos.seeConcept',
    duration: 'demos.comingSoon',
    available: false,
    external: false,
  },
];
---

<section class="py-20 bg-surface" id="demo-center">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-3xl lg:text-4xl font-bold text-navy text-center mb-4">
      {t(locale, 'demos.title')}
    </h2>
    <p class="text-text-light text-center mb-14 max-w-2xl mx-auto">
      {locale === 'ro' ? 'Exploreaza demo-urile solutiilor noastre si vezi cum functioneaza in practica.' : 'Explore our solution demos and see how they work in practice.'}
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {demos.map((demo, i) => (
        <a href={demo.href} target={demo.external ? '_blank' : undefined} rel={demo.external ? 'noopener noreferrer' : undefined} class="group block p-6 bg-white rounded-2xl border border-gray-100 hover:border-primary/30 hover:shadow-lg transition-all duration-300" data-animate data-animate-delay={String((i % 4) + 1)}>
          <!-- Screenshot placeholder -->
          <div class={`w-full h-36 rounded-xl mb-5 flex items-center justify-center ${demo.available ? 'bg-primary/5' : 'bg-gray-50'}`}>
            <div class="text-center">
              <div class={`w-12 h-12 rounded-xl mx-auto mb-2 flex items-center justify-center ${demo.available ? 'bg-primary/10' : 'bg-gray-100'}`}>
                <svg class={`w-6 h-6 ${demo.available ? 'text-primary' : 'text-gray-400'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <span class="text-xs text-text-light">{t(locale, demo.duration)}</span>
            </div>
          </div>

          <h3 class="font-heading text-lg font-bold text-navy mb-2 group-hover:text-primary transition-colors">{demo.name}</h3>
          <p class="text-sm text-text-light mb-4 leading-relaxed">{demo.useCase}</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary">
            {t(locale, demo.ctaKey)}
            {demo.external ? (
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            ) : (
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            )}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
