---
import Layout from '../../layouts/Layout.astro';
import CTAFinal from '../../components/CTAFinal.astro';
import { getLocaleFromUrl, t } from '../../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const areas = ['about.area1', 'about.area2', 'about.area3', 'about.area4'];
const areaIcons = [
  'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
];
---

<Layout title={t(locale, 'about.title')} description="We develop AI solutions for automating complex internal processes.">
  <section class="pt-28 pb-16 lg:pt-36 lg:pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-navy text-center mb-8">
        {t(locale, 'about.title')}
      </h1>
      <p class="text-lg text-text-light text-center leading-relaxed max-w-2xl mx-auto mb-16">
        {t(locale, 'about.intro')}
      </p>

      <h2 class="font-heading text-2xl lg:text-3xl font-bold text-navy mb-10 text-center">
        {t(locale, 'about.areasTitle')}
      </h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {areas.map((key, i) => (
          <div class="flex items-start gap-4 p-6 bg-surface rounded-2xl" data-animate data-animate-delay={String(i + 1)}>
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={areaIcons[i]}/>
              </svg>
            </div>
            <div>
              <h3 class="font-heading text-lg font-semibold text-navy">{t(locale, key)}</h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTAFinal />
</Layout>
