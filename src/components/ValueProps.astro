---
import { getLocaleFromUrl, t } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);

const values = [
  { key: 'value.v1', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
  { key: 'value.v2', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
  { key: 'value.v3', icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z' },
  { key: 'value.v4', icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2' },
  { key: 'value.v5', icon: 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z' },
  { key: 'value.v6', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
];
---

<section class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-3xl lg:text-4xl font-bold text-navy text-center mb-14">
      {t(locale, 'value.title')}
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {values.map((v, i) => (
        <div class="flex items-start gap-4 p-6 bg-surface rounded-xl" data-animate data-animate-delay={String((i % 4) + 1)}>
          <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={v.icon}/>
            </svg>
          </div>
          <p class="text-text font-medium leading-relaxed">{t(locale, v.key)}</p>
        </div>
      ))}
    </div>
  </div>
</section>
