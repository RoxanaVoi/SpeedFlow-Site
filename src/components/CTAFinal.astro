---
import { getLocaleFromUrl, t, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
---

<section class="py-20 bg-navy">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-heading text-3xl lg:text-4xl font-bold text-white mb-6">
      {t(locale, 'ctaFinal.title')}
    </h2>
    <p class="text-lg text-white/70 mb-10 leading-relaxed">
      {t(locale, 'ctaFinal.sub')}
    </p>
    <a href={getLocalizedPath(locale, '/contact')} class="inline-block px-8 py-4 bg-primary text-white font-semibold rounded-lg hover:bg-primary-light transition-colors text-lg">
      {t(locale, 'ctaFinal.cta')}
    </a>
  </div>
</section>
